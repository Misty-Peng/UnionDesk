{
  "name": "uniondesk-web",
  "private": true,
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "dev:customer": "pnpm --filter customer-web dev",
    "dev:admin": "pnpm --filter admin-web dev",
    "dev": "pnpm --filter admin-web dev",
    "check:utf8": "node ./scripts/check-utf8.mjs",
    "build:admin": "pnpm --filter admin-web build",
    "lint:admin": "pnpm run check:utf8 && pnpm --filter admin-web lint",
    "typecheck:admin": "pnpm --filter admin-web typecheck",
    "build": "pnpm -r build",
    "lint": "pnpm run check:utf8 && pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  }
}
